    {
      "variable_name": "listed_year",
      "section": "profile",
      "usage_role": "feature_x",
      "korean_name": "상장연도",
      "description": "상장일에서 추출한 연도",
      "source": "Profile",
      "formula_or_logic": "상장일의 연도",
      "unit": "year",
      "note": "",
      "order": 12
    },
    {
      "variable_name": "firm_size_group",
      "section": "profile",
      "usage_role": "feature_x",
      "korean_name": "기업규모 그룹",
      "description": "모델링용 기업규모 그룹",
      "source": "Derived from Profile",
      "formula_or_logic": "대기업/중견기업/중소기업/기타 그룹화",
