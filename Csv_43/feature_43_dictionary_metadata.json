    {
      "variable_name": "industry_macro_category",
      "section": "profile",
      "usage_role": "feature_x",
      "korean_name": "산업 대분류",
      "description": "모델링용 산업 대분류",
      "source": "Derived from Profile",
      "formula_or_logic": "제조업/건설업/도소매업/IT·서비스업/운수·창고업/기타",
      "unit": "category",
      "note": "",
