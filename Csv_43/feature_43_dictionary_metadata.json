    },
    {
      "variable_name": "assets_total",
      "section": "financial_bs",
      "usage_role": "feature_x",
      "korean_name": "자산총계",
      "description": "총자산",
      "source": "BS",
      "formula_or_logic": "원천값",
      "unit": "KRW thousand",
      "note": "",
      "order": 26
    },
    {
      "variable_name": "gross_profit",
      "section": "financial_is",
      "usage_role": "feature_x",
      "korean_name": "매출총이익",
