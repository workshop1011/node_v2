      "source": "IS",
      "formula_or_logic": "원천값",
      "unit": "KRW thousand",
      "note": "",
      "order": 46
    },
    {
      "variable_name": "depreciation",
      "section": "financial_cf",
      "usage_role": "feature_x",
      "korean_name": "감가상각비",
      "description": "감가상각비",
      "source": "CF",
      "formula_or_logic": "원천값",
      "unit": "KRW thousand",
      "note": "",
      "order": 55
    },
    {
      "variable_name": "spec_spread",
      "section": "macro",
      "usage_role": "feature_x",
      "korean_name": "투기경계 스프레드",
      "description": "회사채 BBB-와 AA- 간 스프레드",
      "source": "ECOS_Macro_Processed.csv",
      "formula_or_logic": "corp_bbb_3y - corp_aa_3y",
      "unit": "%p",
      "note": "",
      "order": 65
    },
    {
      "variable_name": "dividend_payer",
      "section": "market_features",
      "usage_role": "feature_x",
      "korean_name": "배당금 지급 여부",
      "description": "해당 회계연도에 현금배당을 지급했는지 여부",
      "source": "KOSPI_market_and_div.csv / KOSDAQ_market_and_div.csv",
      "formula_or_logic": "종목코드-회계년도 그룹 내 배당금지급(-) 값이 0이 아니면 1, 아니면 0",
      "unit": "0/1",
      "note": "기존 공식 변수셋에서도 중요하게 보던 배당 관련 안정성 지표",
      "order": 67
    },
    {
      "variable_name": "market_to_book",
      "section": "market_features",
      "usage_role": "feature_x",
      "korean_name": "Market-to-Book",
      "description": "시가총액 대비 장부가치 비율",
      "source": "KOSPI_market_and_div.csv / KOSDAQ_market_and_div.csv + BS",
      "formula_or_logic": "market_cap / (equity_total * 1000)",
      "unit": "ratio",
      "note": "자본총계가 천원 단위이므로 1000을 곱해 계산. 기존 공식 변수셋에서도 사용된 규모 지표",
      "order": 68
    },
    {
      "variable_name": "current_ratio",
      "section": "stability",
      "usage_role": "feature_x",
      "korean_name": "유동비율",
      "description": "유동자산 대비 유동부채 비율",
      "source": "Derived from BS",
      "formula_or_logic": "current_assets / current_liabilities",
      "unit": "ratio",
      "note": "",
      "order": 70
    },
    {
      "variable_name": "debt_ratio",
      "section": "stability",
      "usage_role": "feature_x",
      "korean_name": "부채비율",
      "description": "자기자본 대비 총부채 비율",
      "source": "Derived from BS",
      "formula_or_logic": "liabilities_total / equity_total",
      "unit": "ratio",
      "note": "총부채 레버리지 관점 보완 변수",
      "order": 71
    },
    {
      "variable_name": "total_borrowings_ratio",
      "section": "stability",
      "usage_role": "feature_x",
      "korean_name": "총차입금비율",
      "description": "총자산 대비 총차입금 비율",
      "source": "Derived from BS",
      "formula_or_logic": "total_borrowings / assets_total",
      "unit": "ratio",
      "note": "",
      "order": 72
    },
    {
      "variable_name": "short_term_borrowings_share",
      "section": "stability",
      "usage_role": "feature_x",
      "korean_name": "단기차입금 비중",
      "description": "총차입금 중 단기차입금 비중",
      "source": "Derived from BS",
      "formula_or_logic": "short_term_borrowings / total_borrowings",
      "unit": "ratio",
      "note": "기존 공식 변수셋에서 중요하게 보던 단기 유동성 압박 구조 변수",
      "order": 73
    },
    {
      "variable_name": "cash_ratio",
      "section": "stability",
      "usage_role": "feature_x",
      "korean_name": "현금비율",
      "description": "유동부채 대비 현금및현금성자산 비율",
      "source": "Derived from BS",
      "formula_or_logic": "cash_and_equivalents / current_liabilities",
      "unit": "ratio",
      "note": "",
      "order": 75
    },
    {
      "variable_name": "equity_ratio",
      "section": "stability",
      "usage_role": "feature_x",
      "korean_name": "자기자본비율",
      "description": "총자산 대비 자기자본 비율",
      "source": "Derived from BS",
      "formula_or_logic": "equity_total / assets_total",
      "unit": "ratio",
      "note": "",
      "order": 76
    },
    {
      "variable_name": "capital_impairment_ratio",
      "section": "stability",
      "usage_role": "feature_x",
      "korean_name": "자본잠식률",
      "description": "자본금 대비 자본잠식 정도",
      "source": "Derived from BS",
      "formula_or_logic": "(capital_stock - equity_total) / capital_stock",
      "unit": "ratio",
      "note": "양수일수록 자본잠식 신호 가능",
      "order": 77
    },
    {
      "variable_name": "net_margin",
      "section": "profitability",
      "usage_role": "feature_x",
      "korean_name": "순이익률",
      "description": "매출액 대비 당기순이익 비율",
      "source": "Derived from IS",
      "formula_or_logic": "net_income / revenue",
      "unit": "ratio",
      "note": "기존 공식 변수셋에서도 핵심으로 보던 수익성 변수",
      "order": 79
    },
    {
      "variable_name": "pretax_roa",
      "section": "profitability",
      "usage_role": "feature_x",
      "korean_name": "세전계속사업이익 기준 ROA",
      "description": "총자산 대비 세전이익 비율",
      "source": "Derived from IS + BS",
      "formula_or_logic": "pretax_income / assets_total",
      "unit": "ratio",
      "note": "",
      "order": 87
    },
    {
      "variable_name": "operating_roa",
      "section": "profitability",
      "usage_role": "feature_x",
      "korean_name": "총자산영업이익률",
      "description": "총자산 대비 영업이익 비율",
      "source": "Derived from IS + BS",
      "formula_or_logic": "operating_income / assets_total",
      "unit": "ratio",
      "note": "",
      "order": 88
    },
    {
      "variable_name": "pretax_roe",
      "section": "profitability",
      "usage_role": "feature_x",
      "korean_name": "세전계속사업이익 기준 ROE",
      "description": "자기자본 대비 세전이익 비율",
      "source": "Derived from IS + BS",
      "formula_or_logic": "pretax_income / equity_total",
      "unit": "ratio",
      "note": "",
      "order": 89
    },
    {
      "variable_name": "total_debt_turnover",
      "section": "profitability",
      "usage_role": "feature_x",
      "korean_name": "총부채회전율",
      "description": "총부채 대비 매출액 비율",
      "source": "Derived from IS + BS",
      "formula_or_logic": "revenue / liabilities_total",
      "unit": "ratio",
      "note": "",
      "order": 93
    },
    {
      "variable_name": "is_2y_consecutive_operating_loss",
      "section": "trend",
      "usage_role": "feature_x",
      "korean_name": "2년 연속 영업적자 여부",
      "description": "당기와 전기 모두 영업이익이 음수인지 여부",
      "source": "Derived from IS history",
      "formula_or_logic": "operating_income_t < 0 and operating_income_t-1 < 0",
      "unit": "0/1",
      "note": "지속적 수익성 악화 신호",
      "order": 112
    },
    {
      "variable_name": "is_2y_consecutive_ocf_deficit",
      "section": "trend",
      "usage_role": "feature_x",
      "korean_name": "2년 연속 OCF 적자 여부",
      "description": "당기와 전기 모두 영업현금흐름이 음수인지 여부",
      "source": "Derived from CF history",
      "formula_or_logic": "ocf_t < 0 and ocf_t-1 < 0",
      "unit": "0/1",
      "note": "지속적 현금흐름 악화 신호",
      "order": 113
    },
    {
      "variable_name": "icr_under_1",
      "section": "trend",
      "usage_role": "feature_x",
      "korean_name": "ICR 1 미만 여부",
      "description": "이자보상배율이 1 미만인지 여부 (영업이익으로 이자도 못 내는 상태)",
      "source": "Derived from interest_coverage_ratio",
      "formula_or_logic": "interest_coverage_ratio < 1 이면 1",
      "unit": "0/1",
      "note": "",
      "order": 114
    },
    {
      "variable_name": "accruals_ratio",
      "section": "trend",
      "usage_role": "feature_x",
      "korean_name": "발생액 비율",
      "description": "총자산 대비 순이익과 영업현금흐름의 차이 (이익품질 지표)",
      "source": "Derived from IS + CF + BS",
      "formula_or_logic": "(net_income - ocf) / assets_total",
      "unit": "ratio",
      "note": "양수면 현금흐름 대비 회계이익 과다 — 이익 과장 신호",
      "order": 116
    },
    {
      "variable_name": "net_margin_diff",
      "section": "trend",
      "usage_role": "feature_x",
      "korean_name": "순이익률 변화",
      "description": "전년 대비 순이익률 변화폭",
      "source": "Derived from net_margin history",
      "formula_or_logic": "net_margin_t - net_margin_t-1",
      "unit": "ratio",
      "note": "",
      "order": 127
    },
    {
      "variable_name": "total_assets_growth",
      "section": "growth",
      "usage_role": "feature_x",
      "korean_name": "총자산증가율",
      "description": "전년 대비 총자산 증가율",
      "source": "Derived from BS history",
      "formula_or_logic": "(assets_total_t - assets_total_t-1) / assets_total_t-1",
      "unit": "ratio",
      "note": "자산 축소/급팽창은 구조조정·무리한 확장 신호",
      "order": 138
    },
    {
      "variable_name": "interest_coverage_ratio",
      "section": "cashflow_solvency",
      "usage_role": "feature_x",
      "korean_name": "이자보상배율",
      "description": "영업이익 대비 이자비용 배수",
      "source": "Derived from IS",
      "formula_or_logic": "operating_income / interest_expense",
      "unit": "ratio",
      "note": "이자비용 0이면 1,000,000으로 capped",
      "order": 147
    },
    {
      "variable_name": "ocf_to_sales",
      "section": "cashflow_solvency",
      "usage_role": "feature_x",
      "korean_name": "OCF/매출액",
      "description": "매출액 대비 영업현금흐름 비율",
      "source": "Derived from CF + IS",
      "formula_or_logic": "ocf / revenue",
      "unit": "ratio",
      "note": "",
      "order": 148
    },
    {
      "variable_name": "ocf_to_total_borrowings",
      "section": "cashflow_solvency",
      "usage_role": "feature_x",
      "korean_name": "OCF/총차입금",
      "description": "총차입금 대비 영업현금흐름 비율",
      "source": "Derived from CF + BS",
      "formula_or_logic": "ocf / total_borrowings",
      "unit": "ratio",
      "note": "",
      "order": 149
    },
    {
      "variable_name": "ocf_to_total_liabilities",
      "section": "cashflow_solvency",
      "usage_role": "feature_x",
      "korean_name": "OCF/부채총계",
      "description": "총부채 대비 영업현금흐름 비율",
      "source": "Derived from CF + BS",
      "formula_or_logic": "ocf / liabilities_total",
      "unit": "ratio",
      "note": "",
      "order": 150
    },
    {
      "variable_name": "cashflow_coverage_ratio",
      "section": "cashflow_solvency",
      "usage_role": "feature_x",
      "korean_name": "현금흐름 커버리지",
      "description": "이자비용 대비 영업현금흐름 배수",
      "source": "Derived from CF + IS",
      "formula_or_logic": "ocf / interest_expense",
      "unit": "ratio",
      "note": "이자비용 0이면 1,000,000으로 capped",
      "order": 153
    },
    {
      "variable_name": "intangible_assets_ratio",
      "section": "business_structure",
      "usage_role": "feature_x",
      "korean_name": "무형자산 비중",
      "description": "총자산 대비 무형자산 비율",
      "source": "Derived from BS",
      "formula_or_logic": "intangible_assets / assets_total",
      "unit": "ratio",
      "note": "",
      "order": 161
    }
  ]
}
